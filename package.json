{
  "name": "react-actionkit",
  "version": "0.1.1",
  "description": "Headless React actions, keyboard shortcuts, and command palette state.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saicharanar/actionkit.git"
  },
  "bugs": {
    "url": "https://github.com/saicharanar/actionkit/issues"
  },
  "homepage": "https://github.com/saicharanar/actionkit#readme",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "ci": "npm run typecheck && npm run test && npm run build && npm audit",
    "demo": "vite --config examples/demo/vite.config.ts --host localhost",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.2.0 || >=19.0.0",
    "react-dom": ">=18.2.0 || >=19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^4.1.9"
  }
}
